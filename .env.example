# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# RESEND_API_KEY: Required for sending booking emails.
# Sign up at resend.com to get your key.
RESEND_API_KEY="re_..."

# ADMIN_EMAIL: The email address where booking notifications will be sent.
ADMIN_EMAIL="Gurbir.dhaliwxl14@gmail.com"
